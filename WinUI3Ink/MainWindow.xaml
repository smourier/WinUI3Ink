<Window
    x:Class="WinUI3Ink.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WinUI3Ink.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:WinUI3Ink"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="WinUI3 Ink"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel
            Grid.ColumnSpan="2"
            Margin="10"
            HorizontalAlignment="Center"
            Orientation="Horizontal"
            Spacing="12">
            <Button Click="OnSaveLeft">
                Save left as image...
            </Button>
            <Button Click="OnClearLeft">
                Clear left
            </Button>
            <Button Click="OnNewWindow">
                New window on another thread
            </Button>
            <Button Click="OnClearRight">
                Clear right
            </Button>
            <Button Click="OnSaveRight">
                Save right as image...
            </Button>
        </StackPanel>

        <controls:InkCanvas
            x:Name="blackOnWhiteCanvas"
            Grid.Row="1"
            Grid.Column="0"
            Background="White" />

        <controls:InkCanvas
            x:Name="whiteOnBlackCanvas"
            Grid.Row="1"
            Grid.Column="1"
            Background="Black"
            Color="White" />
    </Grid>
</Window>
